{
  "name": "ContentFlow Your Creative Empire",
  "short_name": "ContentFlow",
  "description": "Content planning, ideas, projects and analytics for creators",
  "start_url": "/contentflow/index.html",
  "id": "/contentflow/index.html",
  "scope": "/contentflow/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "orientation": "portrait-primary",
  "background_color": "#08080F",
  "theme_color": "#08080F",
  "lang": "en",
  "dir": "ltr",
  "categories": ["productivity", "lifestyle"],
  "iarc_rating_id": "f1a6b2c3-d4e5-6789-abcd-ef0123456789",
  "related_applications": [],
  "prefer_related_applications": false,
  "handle_links": "preferred",
  "edge_side_panel": { "preferred_width": 480 },
  "share_target": {
    "action": "/contentflow/index.html",
    "method": "GET",
    "params": { "title": "title", "text": "text", "url": "url" }
  },
  "protocol_handlers": [
    { "protocol": "web+contentflow", "url": "/contentflow/index.html?action=%s" }
  ],
  "note_taking": {
    "new_note_url": "/contentflow/index.html?action=new-idea"
  },
  "shortcuts": [
    {
      "name": "New Idea",
      "short_name": "Add Idea",
      "description": "Quickly capture a new content idea",
      "url": "/contentflow/index.html?action=new-idea",
      "icons": [{ "src": "/contentflow/icons/shortcut-idea.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "Dashboard",
      "short_name": "Dashboard",
      "description": "Go to your creator dashboard",
      "url": "/contentflow/index.html?page=dashboard",
      "icons": [{ "src": "/contentflow/icons/shortcut-home.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "Projects",
      "short_name": "Projects",
      "description": "View your content projects",
      "url": "/contentflow/index.html?page=projects",
      "icons": [{ "src": "/contentflow/icons/shortcut-home.png", "sizes": "96x96", "type": "image/png" }]
    }
  ],
  "screenshots": [
    {
      "src": "/contentflow/screenshots/mobile.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
